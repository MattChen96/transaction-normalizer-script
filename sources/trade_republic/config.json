{
  "source": {
    "name": "Trade Republic",
    "version": "2.0",
    "description": "Estratti conto Trade Republic in formato CSV app — include transazioni cash e trading"
  },

  "file": {
    "format": "csv",
    "encoding": "utf-8",
    "delimiter": ",",
    "skip_rows": 0,
    "header_row": 0,
    "decimal_separator": ".",
    "thousands_separator": "",
    "quotechar": "\""
  },

  "filters": {
    "include": [
      {
        "column": "account_type",
        "operator": "equals",
        "value": "DEFAULT",
        "case_sensitive": false
      }
    ],
    "exclude": [
      {
        "column": "type",
        "operator": "in",
        "value": ["BUY", "SELL", "DEPOSIT", "WITHDRAWAL"],
        "case_sensitive": false
      },
      {
        "column": "category",
        "operator": "equals",
        "value": "TRADING",
        "case_sensitive": false
      },
      {
        "column": "type",
        "operator": "equals",
        "value": "CARD_ORDERING_FEE",
        "case_sensitive": false
      }
    ]
  },

  "fields": {
    "Data": {
      "input_column": "date",
      "transform": [
        {
          "type": "trim"
        }
      ]
    },

    "Acquisto": {
      "input_column": "description",
      "transform": [
        {
          "type": "trim"
        },
        {
          "type": "regex_replace",
          "pattern": "^SumUp\\s+\\*",
          "replacement": ""
        }
      ]
    },

    "Importo": {
      "input_column": "amount",
      "transform": [
        {
          "type": "trim"
        },
        {
          "type": "number_normalize",
          "decimal_separator": ".",
          "thousands_separator": ""
        },
        {
          "type": "number_round",
          "decimals": 2
        }
      ]
    },

    "Categoria": {
      "input_column": "mcc_code",
      "transform": [
        {
          "type": "trim"
        }
      ],
      "category_mapping": {
        "map": {
