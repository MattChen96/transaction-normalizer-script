        "case_sensitive": false,
        "default": "🎲 Altro"
      },
      "embedding_fallback": {
        "source_column": "description",
        "threshold": 0.20
      },
      "default": "🎲 Altro"
    },

    "Tag": {
      "constant": ""
    },

    "Wallet": {
      "constant": "Trade Republic"
    },

    "Note": {
      "input_column": "type",
      "transform": [
        {
          "type": "conditional",
          "conditions": [
            {
              "if_column": "type",
              "operator": "equals",
              "value": "INTEREST_PAYMENT",
              "then": "Interessi"
            },
            {
              "if_column": "type",
              "operator": "equals",
              "value": "BENEFITS_SAVEBACK",
              "then": "Cashback/Reward"
            },
            {
              "if_column": "type",
              "operator": "equals",
              "value": "TRANSFER_INBOUND",
              "then": "Trasferimento in entrata"
            },
            {
              "if_column": "type",
              "operator": "equals",
              "value": "TRANSFER_DIRECT_DEBIT_INBOUND",
              "then": "Addebito diretto"
            }
          ],
          "else": ""
        }
      ],
      "default": ""
    }
  }
}
