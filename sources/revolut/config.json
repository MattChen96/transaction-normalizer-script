{
  "source": {
    "name": "Revolut",
    "version": "3.0",
    "description": "Estratti conto Revolut — formato CSV italiano (export it-it da app)"
  },

  "file": {
    "format": "csv",
    "encoding": "utf-8",
    "delimiter": ",",
    "skip_rows": 0,
    "header_row": 0,
    "decimal_separator": ".",
    "thousands_separator": "",
    "quotechar": "\""
  },

  "filters": {
    "include": [
      {
        "column": "State",
        "operator": "equals",
        "value": "COMPLETATO",
        "case_sensitive": false
      },
      {
        "column": "Prodotto",
        "operator": "equals",
        "value": "Attuale",
        "case_sensitive": false
      }
    ],
    "exclude": []
  },

  "fields": {
    "Data": {
      "input_column": "Data di completamento",
      "transform": [
        { "type": "trim" },
        {
          "type": "date_format",
          "input_format": "%Y-%m-%d %H:%M:%S",
          "output_format": "%Y-%m-%d"
        }
      ]
    },

    "Acquisto": {
      "input_column": "Descrizione",
      "transform": [
        { "type": "trim" },
        {
          "type": "regex_replace",
          "pattern": "^Pagamento (a favore|da parte) di ",
          "replacement": ""
        }
      ]
    },

    "Importo": {
      "input_column": "Importo",
      "transform": [
        { "type": "trim" },
        {
          "type": "number_normalize",
          "decimal_separator": ".",
          "thousands_separator": ""
        },
        { "type": "number_round", "decimals": 2 }
      ]
    },

    "Categoria": {
      "input_column": "Tipo",
      "transform": [
        { "type": "trim" },
        { "type": "lowercase" }
      ],
      "category_mapping": {
        "map": {
          "pagamento con carta": "🎲 Altro",
          "pagamento":          "🎲 Altro",
          "interessi":          "🎫 Abbonamenti"
        },
        "case_sensitive": false,
        "default": "🎲 Altro"
      },
      "embedding_fallback": {
        "source_column": "Descrizione",
        "threshold": 0.20
      },
      "default": "🎲 Altro"
    },

    "Tag": {
      "constant": ""
    },

    "Wallet": {
      "constant": "Revolut"
    },

    "Note": {
      "input_column": "Tipo",
      "transform": [
        { "type": "trim" }
      ],
      "default": ""
    }
  }
}
